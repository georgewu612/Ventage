# Ventage Environment Variables
# Copy this to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (Frontend - NEXT_PUBLIC_ prefix required for client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Frontend API Base URL (production: https://your-api.railway.app)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend CORS — set to your Vercel deployment URL in production
# FRONTEND_URL=https://ventage.vercel.app

# OpenClaw
OPENCLAW_API_URL=http://localhost:18789

# Telegram (for alerts)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# OpenAI (for AI-driven analysis reports)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini  # gpt-4o-mini (cheap) or gpt-4o (quality)

# Alpha Vantage (for TradingAgents market data)
ALPHAVANTAGE_API_KEY=your-alphavantage-key

# Stripe (billing)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Get Price IDs from https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_PREMIUM_PRICE_ID=price_your_premium_monthly_price_id

# Optional: External Data APIs
# POLYGON_API_KEY=
# UNUSUAL_WHALES_API_KEY=

# Alpaca (free tier — used for 4h multi-timeframe signal confirmation)
# Sign up at https://alpaca.markets/ → API Keys → Paper trading
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
