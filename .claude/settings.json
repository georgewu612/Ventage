{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -qE '(\\.env$|\\.env\\.local|\\.env\\.production|package-lock\\.json)' && echo 'BLOCKED: Cannot edit .env or lock files' && exit 1 || exit 0"
          }
        ]
      }
    ]
  }
}
