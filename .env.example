# Ventage Environment Variables
# Copy this to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (Frontend - NEXT_PUBLIC_ prefix required for client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Frontend API Base URL (production: https://your-api.railway.app)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend CORS — set to your Vercel deployment URL in production
# FRONTEND_URL=https://ventage.vercel.app

# OpenClaw
OPENCLAW_API_URL=http://localhost:18789

# Telegram (for alerts)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Optional: External Data APIs
# POLYGON_API_KEY=
# UNUSUAL_WHALES_API_KEY=
